# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Instagram session ID for scraping (from a dedicated monitoring account)
# To get: log into Instagram in Chrome → DevTools → Application → Cookies → sessionid
IG_SESSION_ID=

# Instagram username for the monitoring account
IG_USERNAME=

# (Optional) How many recent posts to fetch per vendor per run
POSTS_PER_VENDOR=10

# (Optional) Seconds to wait between scraping each profile (min 30)
SCRAPE_DELAY_SECONDS=45
